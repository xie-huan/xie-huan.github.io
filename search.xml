<pre><code>&lt;Figure size 640x480 with 1 Axes&gt;
</code></pre><figure class="highlight python"><table><tr><td class="code"><pre><span class="line"><span class="comment"># 拆分数据为训练集、测试集</span></span><br><span class="line"><span class="keyword">from</span> sklearn.model_selection <span class="keyword">import</span> train_test_split</span><br><span class="line">x_train,x_test,y_train,y_test = train_test_split(x,y,random_state=<span class="number">666</span>)</span><br><span class="line"></span><br><span class="line"><span class="comment"># 调用自己实现的简单线性回归</span></span><br><span class="line"><span class="keyword">from</span> Machine_Learning.LinearReg.SimpleLinearRegression <span class="keyword">import</span> SimpleLinearRegression2</span><br><span class="line">reg = SimpleLinearRegression2()</span><br><span class="line">reg.fit(x_train,y_train)</span><br><span class="line">y_predict = reg.predict(x_test)</span><br></pre></td></tr></table></figure>
